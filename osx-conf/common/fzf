# vim: ft=zsh sw=2 ts=2 expandtab

# Interactive TTY only to avoid zle errors in automation contexts.
[[ -o interactive && -t 1 ]] || return 0

# Load fzf key bindings and completion for Zsh.
# Prefer the generated ~/.fzf.zsh file, but fall back to the Homebrew install
# so Ctrl+R works even if the fzf install script was never run.
if [ -f ~/.fzf.zsh ]; then
  source ~/.fzf.zsh
elif command -v brew >/dev/null 2>&1; then
  FZF_PREFIX="$(brew --prefix fzf 2>/dev/null)"
  if [ -n "$FZF_PREFIX" ]; then
    [ -f "$FZF_PREFIX/shell/completion.zsh" ] && source "$FZF_PREFIX/shell/completion.zsh"
    [ -f "$FZF_PREFIX/shell/key-bindings.zsh" ] && source "$FZF_PREFIX/shell/key-bindings.zsh"
  fi
  unset FZF_PREFIX
fi

# Set fzf default options.
export FZF_DEFAULT_OPTS='--height 40% --reverse --border'
